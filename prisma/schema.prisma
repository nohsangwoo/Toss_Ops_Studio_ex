generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  READY
  IN_PROGRESS
  DONE
  CANCELED
  PARTIAL_CANCELED
  ABORTED
  EXPIRED
  FAILED
}

enum DirectFarmOrderStatus {
  DRAFT
  PAYMENT_PENDING
  PAID
  FAILED
  CANCELED
}

enum DirectFarmNotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  orderName       String
  customerName    String?
  customerEmail   String?
  customerKey     String
  amount          Int
  currency        String        @default("KRW")
  status          PaymentStatus @default(READY)
  method          String?
  paymentKey      String?       @unique
  approvedAt      DateTime?
  requestedAt     DateTime?
  receiptUrl      String?
  rawResponse     Json?
  failureCode     String?
  failureMessage  String?
  canceledAmount  Int           @default(0)
  cancelReason    String?
  canceledAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  events          PaymentEvent[]
}

model PaymentEvent {
  id        String   @id @default(cuid())
  paymentId String
  type      String
  payload   Json
  createdAt DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model DirectFarmVendor {
  id          String              @id @default(cuid())
  name        String
  managerName String
  phone       String
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    DirectFarmProduct[]
  orders      DirectFarmOrder[]

  @@index([isActive])
}

model DirectFarmProduct {
  id             String              @id @default(cuid())
  slug           String              @unique
  name           String
  description    String
  imageUrl       String
  origin         String
  unit           String
  salePrice      Int
  wholesalePrice Int
  isActive       Boolean             @default(true)
  sortOrder      Int                 @default(0)
  vendorId       String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  vendor         DirectFarmVendor    @relation(fields: [vendorId], references: [id])
  orders         DirectFarmOrder[]

  @@index([isActive, sortOrder])
  @@index([vendorId])
}

model DirectFarmOrder {
  id                 String                       @id @default(cuid())
  orderId            String                       @unique
  productId          String
  vendorId           String
  buyerName          String
  buyerPhone         String
  address            String
  addressDetail      String?
  quantity           Int                          @default(1)
  amount             Int
  currency           String                       @default("KRW")
  status             DirectFarmOrderStatus        @default(DRAFT)
  notificationStatus DirectFarmNotificationStatus @default(PENDING)
  customerKey        String
  paymentKey         String?                      @unique
  method             String?
  receiptUrl         String?
  requestedAt        DateTime?
  approvedAt         DateTime?
  rawResponse        Json?
  failureCode        String?
  failureMessage     String?
  sentAt             DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  product            DirectFarmProduct            @relation(fields: [productId], references: [id])
  vendor             DirectFarmVendor             @relation(fields: [vendorId], references: [id])
  notificationLogs   DirectFarmNotificationLog[]

  @@index([productId])
  @@index([vendorId])
  @@index([status, createdAt])
  @@index([notificationStatus])
}

model DirectFarmNotificationLog {
  id             String                       @id @default(cuid())
  orderId        String
  recipientPhone String
  channel        String
  provider       String                       @default("mock")
  status         DirectFarmNotificationStatus
  payload        Json
  errorMessage   String?
  sentAt         DateTime?
  createdAt      DateTime                     @default(now())
  order          DirectFarmOrder              @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}
